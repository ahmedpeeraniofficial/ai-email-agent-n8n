        "messages": {
          "values": [
            {
              "content": "=You are a premium, friendly customer support assistant. Write a reassuring and polite email reply to this customer who has just placed an order.\n\nCustomer Email:\n\"{{ $json.snippet }}\"\n\nYou MUST return your response ONLY as a raw JSON object with exactly two keys: \"subject\" and \"email_body\". Do not include any explanation, do not include markdown code blocks like ```json, and do not put it inside an array.\n\nJSON Format:\n{\n  \"subject\": \"Write a warm, professional subject line here\",\n  \"email_body\": \"Write the complete email body here, formatted with proper line breaks (\\n).\"\n}\n\nIn your email body:\n1. Start with a warm greeting and thank them sincerely for ordering with us.\n2. Acknowledge the item/order mentioned in their email.\n3. Inform them that our fulfillment team is already processing their order.\n4. Politely mention that we will send them another update with the tracking number soon.\n5. End with a sweet customer service closing.\n6. Keep the tone friendly, enthusiastic, and premium.\n7. Sign off professionally as \"Customer Support Team\".\n"
            }
          ]
        },
        "jsonOutput": true,
        "builtInTools": {},
        "options": {}
